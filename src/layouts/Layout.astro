---
import "../styles/global.css";
import { href } from "../lib/url";

interface Props {
  title: string;
}
const { title } = Astro.props;
const nav = [
  { href: href("/"), label: "Start" },
  { href: href("/pokemon/"), label: "Pokémon" },
  { href: href("/formen/"), label: "Formen" },
  { href: href("/shiny/"), label: "Shiny" },
  { href: href("/attacken/"), label: "Attacken" },
  { href: href("/faehigkeiten/"), label: "Fähigkeiten" },
  { href: href("/items/"), label: "Items" },
  { href: href("/trainer/"), label: "Trainer" },
  { href: href("/medaillen/"), label: "Medaillen" },
];
const currentPath = Astro.url.pathname;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={href("/favicon.svg")} />
    <title>{title} · Chronoria-Wiki</title>
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="page">
        <a class="site-title" href={href("/")}>Chronoria-Wiki</a>
        <div class="nav-menu">
          <button type="button" class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-dropdown">
            Menü
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <nav class="site-nav nav-dropdown" id="nav-dropdown" aria-label="Hauptnavigation" hidden>
            {nav.map((item) => (
              <a href={item.href} aria-current={(currentPath.startsWith(item.href) && item.href !== href("/")) || currentPath === item.href ? "page" : undefined}>
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </div>
    </header>
    <main class="page">
      <slot />
    </main>

    <script>
      // Scroll-reveal: fade+lift each top-level section of the page as it enters the
      // viewport. Applied generically here (not per-page) so every page gets it for free.
      // Skips the <h1> so the page title is visible immediately on load.
      //
      // threshold must stay 0 (not e.g. 0.08): threshold is a fraction of the TARGET's own
      // area, not "any part visible" - some pages have a single huge target (e.g. the 1082-item
      // grid, far taller than the viewport), and that fraction can never be reached, so the
      // element stayed opacity:0 forever. threshold:0 fires as soon as even one pixel is in view.
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!prefersReducedMotion) {
        const targets = document.querySelectorAll("main.page > :not(h1)");
        const reveal = (el: Element) => el.classList.add("is-visible");
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                reveal(entry.target);
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0 }
        );
        targets.forEach((el, i) => {
          el.classList.add("reveal");
          (el as HTMLElement).style.transitionDelay = `${Math.min(i, 6) * 40}ms`;
          io.observe(el);
        });
        // Safety net: never let content stay permanently invisible if the observer somehow
        // misses an element - force-reveal everything after a short delay regardless.
        setTimeout(() => targets.forEach(reveal), 1500);
      }
    </script>

    <script>
      // Auto-hide header: slide it up out of view when scrolling down, bring it back when
      // scrolling up (or near the top). Runs on every page via this shared layout.
      const header = document.querySelector<HTMLElement>(".site-header")!;
      let lastY = window.scrollY;
      let ticking = false;
      const HIDE_AFTER_PX = 80; // don't hide while still near the top of the page

      function onScroll() {
        const y = window.scrollY;
        if (y > lastY && y > HIDE_AFTER_PX) {
          header.classList.add("site-header--hidden");
        } else if (y < lastY) {
          header.classList.remove("site-header--hidden");
        }
        lastY = y;
        ticking = false;
      }

      window.addEventListener("scroll", () => {
        if (!ticking) {
          requestAnimationFrame(onScroll);
          ticking = true;
        }
      });
    </script>

    <script>
      // Nav dropdown: toggle on button click, close on outside click or Escape.
      const navToggle = document.getElementById("nav-toggle")!;
      const navDropdown = document.getElementById("nav-dropdown")!;

      function closeNav() {
        navDropdown.hidden = true;
        navToggle.setAttribute("aria-expanded", "false");
      }

      navToggle.addEventListener("click", () => {
        const isOpen = !navDropdown.hidden;
        if (isOpen) {
          closeNav();
        } else {
          navDropdown.hidden = false;
          navToggle.setAttribute("aria-expanded", "true");
        }
      });

      document.addEventListener("click", (e) => {
        if (navDropdown.hidden) return;
        const target = e.target as Node;
        if (!navDropdown.contains(target) && !navToggle.contains(target)) closeNav();
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !navDropdown.hidden) closeNav();
      });
    </script>
  </body>
</html>
