---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import Table from "../../components/Table.astro";
import { items, slugify, moveById } from "../../lib/data";
import { pocketName } from "../../lib/itemPockets";
import { itemLocationSourceLabel } from "../../lib/itemLocationSource";
import { href } from "../../lib/url";

export function getStaticPaths() {
  return items.map((i) => ({ params: { itemId: slugify(i.id) }, props: { i } }));
}

const { i } = Astro.props;
const displayName = i.move ? (moveById.get(i.move)?.name ?? i.name) : i.name;
const locationsByPlace = Object.groupBy
  ? Object.groupBy(i.locations, (l: any) => l.locationName)
  : i.locations.reduce((acc: Record<string, any[]>, l: any) => {
      (acc[l.locationName] ??= []).push(l);
      return acc;
    }, {});
---

<Layout title={displayName}>
  <PageHeader backHref={href("/items/")} backLabel="← Alle Items" title={displayName}>
    {i.icon && <img class="species-sprite" src={href(`/item-icons/${i.icon}${i.iconVersion ? `?v=${i.iconVersion}` : ""}`)} alt="" width="64" height="64" transition:name={`item-icon-${i.id}`} />}
    <p>{i.description || "–"}</p>
  </PageHeader>

  <Table
    rows={[
      ...(i.move ? [{ label: "Name", value: i.name }] : []),
      ...(i.pocket !== 8 ? [{ label: "Preis", value: i.price !== null ? `${i.price} ₽` : "nicht käuflich" }] : []),
      { label: "Tasche", value: pocketName(i.pocket) },
    ]}
  />

  {i.locations.length > 0 && (
    <>
      <h2>Fundorte</h2>
      <table>
        <tr><th>Ort</th><th>Quelle</th></tr>
        {Object.entries(locationsByPlace).map(([place, refs]: [string, any]) => (
          refs.map((r: any, idx: number) => (
            <tr>
              {idx === 0 ? <td rowspan={refs.length}>{place}</td> : null}
              <td>{itemLocationSourceLabel(r.source)}</td>
            </tr>
          ))
        ))}
      </table>
    </>
  )}
</Layout>
