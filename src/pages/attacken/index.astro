---
import Layout from "../../layouts/Layout.astro";
import TypeBadge from "../../components/TypeBadge.astro";
import { moves, types, slugify } from "../../lib/data";
import { href } from "../../lib/url";

const CATEGORY_LABEL: Record<string, string> = { Physical: "Physisch", Special: "Speziell", Status: "Status" };
const sortedMoves = [...moves].sort((a, b) => a.name.localeCompare(b.name, "de"));
---

<Layout title="Attacken">
  <h1>Attacken ({moves.length})</h1>

  <input
    type="search"
    id="name-search"
    class="text-input"
    placeholder="Nach Namen suchen…"
    aria-label="Attacken nach Namen durchsuchen"
  />

  <div class="filter-bar" id="type-filter">
    <a href="#" data-type="ALL" aria-current="true">Alle</a>
    {types.filter((t) => t.id !== "QMARKS").map((t) => (
      <a href="#" data-type={t.id}>{t.name}</a>
    ))}
  </div>

  <p class="meta-note" id="result-count"></p>

  <table id="move-table">
    <tr><th>Attacke</th><th>Typ</th><th>Kategorie</th><th>St.</th><th>Genau.</th><th>AP</th></tr>
    {sortedMoves.map((m) => (
      <tr data-type={m.type} data-name={m.name.toLowerCase()}>
        <td><a href={href(`/attacken/${slugify(m.id)}/`)}>{m.name}</a></td>
        <td><TypeBadge type={m.type} /></td>
        <td>{CATEGORY_LABEL[m.category] ?? m.category}</td>
        <td>{m.power ?? "–"}</td>
        <td>{m.accuracy ?? "–"}</td>
        <td>{m.totalPP ?? "–"}</td>
      </tr>
    ))}
  </table>
</Layout>

<script data-astro-rerun>
  // Block-scoped (see items/index.astro for why: data-astro-rerun re-inserts this exact script on
  // every revisit, and TS-only syntax below must be plain JS since the dynamic re-insertion isn't
  // passed back through Astro/esbuild's TS-stripping step the way the initial page load is.
  {
  const filterBar = document.getElementById("type-filter");
  const nameSearch = document.getElementById("name-search");
  const resultCount = document.getElementById("result-count");
  const rows = [...document.querySelectorAll("#move-table [data-type]")];

  let activeType = "ALL";

  function applyFilters() {
    const query = nameSearch.value.trim().toLowerCase();
    let visible = 0;
    for (const row of rows) {
      const matchesType = activeType === "ALL" || row.dataset.type === activeType;
      const matchesName = query === "" || (row.dataset.name ?? "").includes(query);
      const show = matchesType && matchesName;
      row.style.display = show ? "" : "none";
      if (show) visible++;
    }
    resultCount.textContent = query || activeType !== "ALL" ? `${visible} Treffer` : "";
  }

  filterBar.addEventListener("click", (e) => {
    const link = e.target.closest("a[data-type]");
    if (!link) return;
    e.preventDefault();
    activeType = link.getAttribute("data-type");

    for (const a of filterBar.querySelectorAll("a")) a.removeAttribute("aria-current");
    link.setAttribute("aria-current", "true");
    applyFilters();
  });

  nameSearch.addEventListener("input", applyFilters);
  }
</script>
